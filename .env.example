# Source database (SQLite)
SOURCE_DB_PATH=data/source/retail_source.db

# Local raw staging (JSONL before upload to Databricks)
RAW_OUTPUT_PATH=data/raw

# Extraction batch size
INGESTION_BATCH_SIZE=500

# Databricks Volume path for Bronze raw landing
VOLUME_BRONZE_PATH=dbfs:/Volumes/main/retail/bronze/raw

# Databricks (fill after workspace setup)
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=
DATABRICKS_WAREHOUSE_ID=
